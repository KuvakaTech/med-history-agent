# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env — it contains secrets.
# ──────────────────────────────────────────────────────────────

PROJECT_NAME="Clinical AI"
API_V1_STR="/api/v1"
DEBUG=false

# CORS — comma-separated allowed origins
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
BACKEND_CORS_ALLOW_ALL=false

# ── MongoDB ─────────────────────────────────────────────────
# Local: mongodb://localhost:27017
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=clinical_ai

# ── Cloudflare R2 (optional — for audio storage) ────────────
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=clinical-audio

# ── LLM — at least one provider required ────────────────────
# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001

# Groq — used for streaming when key is set (fastest inference, free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google (Gemini) — used first if GOOGLE_API_KEY is set
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FAST_MODEL=gemini-2.0-flash

# ── Deepgram (STT + TTS) ─────────────────────────────────────
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-luna-en

# ── Auth ──────────────────────────────────────────────────────
# Secret used to sign JWTs — keep this private and rotate periodically.
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15            # Short-lived access token (OAuth2 standard)
REFRESH_TOKEN_EXPIRE_DAYS=7      # Long-lived refresh token stored in httpOnly cookie

# ── Rate limiting (requests per minute, per IP, per worker) ───
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_VOICE=20/minute

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
